// ============================================================
// FRACTAL SMART ZONEZ — by Vic-Forex
// VERSION 1: Detección de Fractales + Estructura Base UDT
// OBJETIVO: Verificar que los fractales se detectan correctamente
// ============================================================
//@version=6
indicator("FSZ v1 — Fractal Detector", overlay = true, max_boxes_count = 50, max_lines_count = 50)

// ─── INPUTS ───────────────────────────────────────────────────
int  i_lookback  = input.int(5,    "Lookback Fractal", minval = 2, maxval = 10, group = "Fractales")
bool i_show_frac = input.bool(true, "Mostrar Fractales",                          group = "Fractales")

// ─── UDT: FRACTAL ─────────────────────────────────────────────
type FSZ_Fractal
    float swing_high
    float swing_low
    int   bar_high
    int   bar_low
    bool  is_bullish
    color box_color

method frac_size(FSZ_Fractal self) =>
    self.swing_high - self.swing_low

method price_inside(FSZ_Fractal self, float price) =>
    price >= self.swing_low and price <= self.swing_high

// ─── UDT: FRACTAL REGISTRY ────────────────────────────────────
type FSZ_Registry
    array<FSZ_Fractal> fractals
    int            max_count
    FSZ_Fractal        last_fractal

method reg_add(FSZ_Registry self, FSZ_Fractal f) =>
    array.push(self.fractals, f)
    self.last_fractal := f
    if array.size(self.fractals) > self.max_count
        array.shift(self.fractals)

method reg_get_last(FSZ_Registry self) =>
    int sz = array.size(self.fractals)
    sz > 0 ? array.get(self.fractals, sz - 1) : na

// ─── FUNCIONES DE DETECCIÓN ───────────────────────────────────
f_is_swing_high(int lb) =>
    bool ok = true
    for i = 1 to lb
        if high[lb] < high[lb - i] or high[lb] < high[lb + i]
            ok := false
    ok

f_is_swing_low(int lb) =>
    bool ok = true
    for i = 1 to lb
        if low[lb] > low[lb - i] or low[lb] > low[lb + i]
            ok := false
    ok

// ─── ESTADO GLOBAL ────────────────────────────────────────────
var FSZ_Registry registry = FSZ_Registry.new(array.new<FSZ_Fractal>(), 20, na)

var float pending_sh     = na
var float pending_sl     = na
var int   pending_sh_bar = na
var int   pending_sl_bar = na

// ─── DETECCIÓN ────────────────────────────────────────────────
bool is_sh = f_is_swing_high(i_lookback)
bool is_sl = f_is_swing_low(i_lookback)

if is_sh
    pending_sh     := high[i_lookback]
    pending_sh_bar := bar_index - i_lookback

if is_sl
    pending_sl     := low[i_lookback]
    pending_sl_bar := bar_index - i_lookback

if not na(pending_sh) and not na(pending_sl)
    bool  bullish = pending_sl_bar < pending_sh_bar
    color col     = bullish ? color.new(color.blue, 80) : color.new(color.red, 80)
    FSZ_Fractal nf    = FSZ_Fractal.new(pending_sh, pending_sl, pending_sh_bar, pending_sl_bar, bullish, col)
    registry.reg_add(nf)
    pending_sh     := na
    pending_sl     := na
    pending_sh_bar := na
    pending_sl_bar := na

// ─── VISUALIZACIÓN ────────────────────────────────────────────
plotshape(i_show_frac and is_sh, "Swing High", shape.triangledown, location.abovebar, color.new(color.red, 0),   size = size.tiny)
plotshape(i_show_frac and is_sl, "Swing Low",  shape.triangleup,   location.belowbar, color.new(color.blue, 0), size = size.tiny)

FSZ_Fractal last = registry.reg_get_last()
if not na(last) and i_show_frac
    int left_bar  = math.min(last.bar_high, last.bar_low)
    int right_bar = math.max(last.bar_high, last.bar_low)
    if bar_index - left_bar < 100
        box.new(left_bar, last.swing_high, right_bar, last.swing_low, border_color = last.is_bullish ? color.blue : color.red, bgcolor = last.box_color, border_width = 1)

// ─── TABLA DE ESTADO ──────────────────────────────────────────
var table tbl = table.new(position.top_right, 2, 5, bgcolor = color.new(color.black, 85), border_color = color.gray, border_width = 1)

if barstate.islast
    table.cell(tbl, 0, 0, "FSZ v1 Fractales",     text_color = color.white, text_size = size.small)
    table.cell(tbl, 1, 0, "",                      text_color = color.white, text_size = size.small)
    table.cell(tbl, 0, 1, "Detectados",            text_color = color.gray,  text_size = size.tiny)
    table.cell(tbl, 1, 1, str.tostring(array.size(registry.fractals)), text_color = color.lime, text_size = size.tiny)

    FSZ_Fractal l = registry.reg_get_last()
    if not na(l)
        table.cell(tbl, 0, 2, "Ultimo fractal", text_color = color.gray, text_size = size.tiny)
        table.cell(tbl, 1, 2, l.is_bullish ? "ALCISTA" : "BAJISTA", text_color = l.is_bullish ? color.lime : color.red, text_size = size.tiny)
        table.cell(tbl, 0, 3, "Swing High",    text_color = color.gray, text_size = size.tiny)
        table.cell(tbl, 1, 3, str.tostring(l.swing_high, "#.####"), text_color = color.red, text_size = size.tiny)
        table.cell(tbl, 0, 4, "Swing Low",     text_color = color.gray, text_size = size.tiny)
        table.cell(tbl, 1, 4, str.tostring(l.swing_low, "#.####"),  text_color = color.blue, text_size = size.tiny)
